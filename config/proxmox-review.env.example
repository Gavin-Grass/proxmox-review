# Copy this file to /etc/proxmox-review/proxmox-review.env.
# Keep the real file out of git.
# This file is sourced by bash. Quote string values.

# Public-safe label. Do not use the real hostname, school name, or site name.
NODE_LABEL="lab-node-1"

# Repo settings for the cloned Git checkout on the Proxmox node.
REPO_DIR="/opt/proxmox-review"
OUTPUT_RELATIVE_PATH="data/report.json"
GIT_REMOTE="origin"
GIT_BRANCH="main"

# Commit identity for automated pushes from the Proxmox node.
GIT_AUTHOR_NAME="Proxmox Review Bot"
GIT_AUTHOR_EMAIL="change-me@example.com"
COMMIT_MESSAGE_PREFIX="Update Proxmox report"

# Auto-publish settings.
# 30 seconds works, but GitHub Pages deployments may lag behind at that speed.
SYNC_INTERVAL_SECONDS=30
AUTO_PUSH=1
GIT_PULL_BEFORE_PUSH=1

# Thresholds used to generate alerts in the JSON report.
CPU_ALERT_PERCENT=90
MEMORY_ALERT_PERCENT=90
SWAP_ALERT_PERCENT=25
ROOT_FS_ALERT_PERCENT=85

# Optional sections
INCLUDE_ZFS=1
INCLUDE_VM_COUNTS=1
INCLUDE_LXC_COUNTS=1
INCLUDE_PVE_SERVICES=1
